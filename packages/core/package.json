{
  "name": "@openstoreshot/core",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./targets": {
      "types": "./src/validation/targets.ts",
      "import": "./src/validation/targets.ts",
      "default": "./dist/validation/targets.js"
    },
    "./node": {
      "types": "./src/project/loadProject.ts",
      "import": "./src/project/loadProject.ts",
      "default": "./dist/project/loadProject.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "vitest run"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
