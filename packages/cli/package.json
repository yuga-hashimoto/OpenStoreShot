{
  "name": "@openstoreshot/cli",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "storeshot": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "storeshot": "tsx src/index.ts"
  },
  "dependencies": {
    "@openstoreshot/core": "workspace:*",
    "@openstoreshot/imagegen": "workspace:*",
    "@openstoreshot/renderer": "workspace:*",
    "@openstoreshot/store-fetch": "workspace:*",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "tsx": "^4.19.1",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
